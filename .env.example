# 本地开发环境变量配置模板
# 在本地开发或 IDEA 运行前，请将本模板复制为你的本地环境变量进行配置

# MySQL 密码 (必须配置)
MYSQL_PASSWORD=your-mysql-password

# Redis 密码 (必须配置)
REDIS_PASSWORD=your-redis-password

# 大模型 OpenAI 兼容接口配置 (必须配置)
AI_BASE_URL=your-openai-compatible-base-url
AI_API_KEY=your-llm-api-key
AI_MODEL=your-llm-model-name

# 头像上传基础目录 (必须配置)
# 可配置为项目目录，后端会自动使用其下的 uploads/ 目录保存头像
# 本地开发示例: UPLOAD_PATH=.
# 服务器部署示例: UPLOAD_PATH=/data/interview-platform
UPLOAD_PATH=your-project-path

# ==========================================
# 以下为可选配置（已有默认值，可不填）
# ==========================================
# SERVER_PORT=8008
# MYSQL_USERNAME=root
# MYSQL_URL=jdbc:mysql://localhost:3306/ai_interview?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&transformedBitIsBoolean=true&allowMultiQueries=true&useSSL=false&allowPublicKeyRetrieval=true
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DATABASE=0
